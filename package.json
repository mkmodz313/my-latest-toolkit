    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.5.2",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
